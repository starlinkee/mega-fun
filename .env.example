# ---------------------------------------------------------------
# Skopiuj ten plik jako .env i uzupelnij wartosci przed startem.
#   cp .env.example .env
# ---------------------------------------------------------------

# Klucz sesji Flask — WYMAGANY.
# Musi byc dlugim, losowym ciagiem znakow. Chroni cookies sesji
# (m.in. stan logowania). Jesli go zmienisz, wszyscy uzytkownicy
# zostana wylogowani.
# Jak wygenerowac:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=zmien-mnie-na-losowy-ciag-znakow

# Haslo do logowania do aplikacji — WYMAGANE.
# Jedna instancja = jeden uzytkownik, wiec to jedyne zabezpieczenie
# przed dostepem do panelu. Uzyj silnego hasla.
APP_PASSWORD=zmien-mnie-na-silne-haslo
